# $(BASEDIR)/../../../Libraries/Qorvo/FactoryData/FactoryData.py


SHELL = /bin/bash

ifndef BASEDIR
BASEDIR:=$(abspath $(dir $(abspath $(lastword $(MAKEFILE_LIST)))))
endif

ROOTDIR?=$(BASEDIR)/../../..
QPG_SDK_ROOT_PATH ?= $(BASEDIR)/../../../

WORKDIR ?= $(BASEDIR)/../../../Work/FactoryData_motionSensor
OUT_FILE := $(WORKDIR)/factory_data.bin
DEP_FILE := $(WORKDIR)/depfile

APP_TARGET := FactoryData_motionSensor.hex

TOOLCHAIN ?= /usr
ifeq (,$(TOOLCHAIN))
# Will use the path variable to find the compiler
Q_TOOLCHAIN_PREFIX=
else
# Use an absolute path, add bin, path separator
Q_TOOLCHAIN_PREFIX= $(TOOLCHAIN)/bin/
endif


GP_DATA_SECTION_START_FACTORYDATA ?= 0x101fd800

GENERATE_FACTORY_DATA ?= qorvo-security-toolbox matter-generator-factory-data
DATA_CONF_FILE ?= $(BASEDIR)/../../../Tools/QorvoPlatformTools/Matter/Credentials/test_motionSensor_qpg6200.factory_data_config
Q_FILE_ARGUMENT=@$(DATA_CONF_FILE)

# always generate depfile to determine dependencies
COMPUTE_DEPFILE_RESULT := $(shell \
    mkdir -p $(WORKDIR) && \
    export QPG_SDK_ROOT=$(QPG_SDK_ROOT_PATH) && \
    $(GENERATE_FACTORY_DATA) $(Q_FILE_ARGUMENT) \
    --write-depfile-and-exit=$(DEP_FILE) \
    --developer \
    --maximum-size=0x800 \
    --magic=QFDA \
    --out-file $(OUT_FILE) \
    )



OBJCOPY ?= $(Q_TOOLCHAIN_PREFIX)arm-none-eabi-objcopy
AR ?= $(Q_TOOLCHAIN_PREFIX)arm-none-eabi-ar

.PHONY:all
all: $(APP_TARGET)

ifeq ("$(wildcard $(DATA_CONF_FILE))","")
$(error $(DATA_CONF_FILE) config file does not exist!)
endif

# NOTE: we 'cd' to the dir that has the .bin file so objcopy will not add in a prefix path to the symbol.
.PRECIOUS: $(OUT_FILE)
-include $(DEP_FILE)
.PRECIOUS: $(OUT_FILE)
$(OUT_FILE): $(DATA_CONF_FILE)
	set -x && \
	mkdir -p $(WORKDIR) && \
    export QPG_SDK_ROOT=$(QPG_SDK_ROOT_PATH) && \
	$(GENERATE_FACTORY_DATA) $(Q_FILE_ARGUMENT) \
    --developer \
    --maximum-size=0x800 \
	--out-file $(OUT_FILE)

.PRECIOUS: $(APP_TARGET)
$(APP_TARGET): $(OUT_FILE)
	set -x && \
	cd $(WORKDIR) && \
    $(OBJCOPY) \
        -I binary -O elf32-littlearm -B armv7e-m \
        --change-section-address=.data=$(GP_DATA_SECTION_START_FACTORYDATA) \
        $(notdir $(OUT_FILE)) temp.elf && \
    $(OBJCOPY) \
        -I elf32-littlearm -O ihex \
        temp.elf $(APP_TARGET) && \
    rm temp.elf \

export_prerequisites: $(APP_TARGET)

.PHONY:clean
clean:
	-rm -r $(WORKDIR)
