#Generated from:
# $(BASEDIR)/../../../Libraries/Qorvo/FactoryData/FirmwareData.py

SHELL = /bin/bash

ifndef BASEDIR
BASEDIR:=$(abspath $(dir $(abspath $(lastword $(MAKEFILE_LIST)))))
endif

ROOTDIR?=$(BASEDIR)/../../..
QPG_SDK_ROOT_PATH ?= $(BASEDIR)/../../../

WORKDIR ?= $(BASEDIR)/../../../Work/FirmwareData_motionSensor
OUT_FILE := $(WORKDIR)/firmware_data.bin
DEP_FILE := $(WORKDIR)/depfile

LIBFIRMWAREDATA_MOTIONSENSOR_A := $(WORKDIR)/libFirmwareData_motionSensor.a

TOOLCHAIN ?= /usr
ifeq (,$(TOOLCHAIN))
# Will use the path variable to find the compiler
Q_TOOLCHAIN_PREFIX=
else
# Use an absolute path, add bin, path separator
Q_TOOLCHAIN_PREFIX= $(TOOLCHAIN)/bin/
endif

GENERATE_FACTORY_DATA = qorvo-security-toolbox matter-generator-factory-data
DATA_CONF_FILE ?= $(BASEDIR)/../../../Tools/QorvoPlatformTools/Matter/Credentials/test_motionSensor.firmware_data_config
Q_FILE_ARGUMENT=@$(DATA_CONF_FILE)

# always generate depfile to determine dependencies
COMPUTE_DEPFILE_RESULT := $(shell \
    mkdir -p $(WORKDIR) && \
    export QPG_SDK_ROOT=$(QPG_SDK_ROOT_PATH) && \
    $(GENERATE_FACTORY_DATA) $(Q_FILE_ARGUMENT) \
    --write-depfile-and-exit=$(DEP_FILE) \
    --developer \
    --out-file $(OUT_FILE) \
    )



OBJCOPY ?= $(Q_TOOLCHAIN_PREFIX)arm-none-eabi-objcopy -I binary -O elf32-littlearm -B armv7e-m
AR ?= $(Q_TOOLCHAIN_PREFIX)arm-none-eabi-ar

.PHONY:all
all: $(LIBFIRMWAREDATA_MOTIONSENSOR_A)

ifeq ("$(wildcard $(DATA_CONF_FILE))","")
$(error $(DATA_CONF_FILE) config file does not exist!)
endif

# NOTE: we 'cd' to the dir that has the .bin file so objcopy will not add in a prefix path to the symbol.
.PRECIOUS: $(OUT_FILE)
-include $(DEP_FILE)
.PRECIOUS: $(OUT_FILE)
$(OUT_FILE): $(DATA_CONF_FILE)
	set -x && \
	mkdir -p $(WORKDIR) && \
    export QPG_SDK_ROOT=$(QPG_SDK_ROOT_PATH) && \
	$(GENERATE_FACTORY_DATA) \
    $(Q_FILE_ARGUMENT) \
    --developer \
    --magic=QFID \
	--out-file $(OUT_FILE)

.PRECIOUS: $(LIBFIRMWAREDATA_MOTIONSENSOR_A)
$(LIBFIRMWAREDATA_MOTIONSENSOR_A): $(OUT_FILE)
	set -x && \
	cd $(WORKDIR) && \
	$(OBJCOPY) \
        --prefix-sections=$(basename $(notdir $(OUT_FILE))) \
        --rename-section .data=firmwaredata,alloc,load,readonly,data,contents \
        $(notdir $(OUT_FILE)) $(basename $(notdir $(OUT_FILE))).o && \
	$(AR) rcs $(shell realpath --canonicalize-missing --relative-to $(WORKDIR) $(LIBFIRMWAREDATA_MOTIONSENSOR_A)) $(basename $(notdir $(OUT_FILE))).o

export_prerequisites: $(LIBFIRMWAREDATA_MOTIONSENSOR_A)

applib: $(LIBFIRMWAREDATA_MOTIONSENSOR_A)

.PHONY:clean
clean:
	-rm -r $(WORKDIR)
